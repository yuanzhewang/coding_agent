# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/

# Env / secrets — never commit your API key
.env
*.key

# Google OAuth (Stage 5) — credentials.json is the app identity, token.json is a
# key to your account. Never commit either.
credentials.json
token.json

# OS / editor
.DS_Store
.idea/
.vscode/

# Scratch space for poking at the agents — never committed.
# Run experiments here (or have the agent write here) and they stay out of git.
experiments/
scratch/

# Runtime agent memory (Stage 4c) — state, not source
agent_memory.md

# Debug RPC log (Stage 3 debug mode) — runtime artifact
rpc_debug.html
